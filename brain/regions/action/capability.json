{
  "region": "action",
  "version": "0.1.0",
  "description": "工具调用、代码执行、结果收集",
  "capabilities": ["execute", "call_tool", "run_code"],
  "subscriptions": [
    {
      "signal_type": "action_request",
      "priority": "high",
      "auto_activate": true
    },
    {
      "signal_type": "plan_step",
      "priority": "normal",
      "auto_activate": true
    }
  ],
  "outputs": [
    "action_result",
    "action_error"
  ],
  "local_improver": {
    "algorithm": "epsilon_greedy_bandit + wilson_confidence",
    "llm_free": true,
    "cycle_interval_seconds": 3600
  },
  "executor": {
    "backend": "subprocess",
    "safety": "forbidden_patterns + tool_whitelist",
    "timeout_default": 30,
    "upgrade_path": ["mcp_servers"]
  }
}
